<h1 >おすすめ曲を投稿</h1>

<%# エラー表示（開発用） %>
<% if @tweet.errors.any? %>
  <div>
    <strong><%= @tweet.errors.count %>件のエラーがあります:</strong>
    <ul>
      <% @tweet.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
    </ul>
  </div>
<% end %>

<%= form_for @tweet do |f| %>
  <div>
    <%= f.label :artist, "アーティスト名（必須）" %><br>
    <%= f.text_field :artist, required: true %>
  </div>

  <div>
    <%= f.label :title, "曲名（必須）" %><br>
    <%= f.text_field :title, required: true %>
  </div>

  <div>
    <%= f.label :body, "おすすめ理由 / コメント（必須）" %><br>
    <%= f.text_area :body, rows: 4, required: true %>
  </div>

  <div>
    <p>タグ（複数選択可）</p>
    <div>
      <%= f.collection_check_boxes(:tag_ids, @all_tags, :id, :name) do |tag| %>
        <label>
          <%= tag.check_box %>
          <%= tag.text %>
        </label>
      <% end %>
    </div>
  </div>

  <%= f.submit "投稿する" %>
<% end %>

<p><%= link_to "← 一覧に戻る", tweets_path %></p>
