
<div class="u-show">

  <header class="u-show__hero">
    <div class="u-show__avatar">
      <% if @user.image&.attached? %>
        <%= image_tag @user.image, class: "u-show__avatar-img", alt: @user.name %>
      <% else %>
        <div class="u-show__avatar-fallback"><%= @user.name.to_s.first&.upcase || "U" %></div>
      <% end %>
    </div>

    <div class="u-show__head">
      <h1 class="u-show__name"><%= @user.name %></h1>
      <p class="u-show__meta"><strong>メール：</strong><%= @user.email %></p>
      <% if @user.respond_to?(:profile) && @user.profile.present? %>
        <p class="u-show__profile"><strong>プロフィール：</strong><%= @user.profile %></p>
      <% end %>

      <% if user_signed_in? && current_user.id == @user.id %>
        <%= link_to "プロフィールを編集", edit_user_registration_path, class: "btn btn--primary" %>
      <% end %>
    </div>
  </header>


  <section class="card u-show__card">
    <h3 class="card__title">サマリー</h3>
    <ul class="stats">
      <li class="stats__item">
        <span class="stats__label">投稿数</span>
        <span class="stats__value"><%= @stats[:posts_count] %></span>
      </li>
      <li class="stats__item">
        <span class="stats__label">もらった いいね</span>
        <span class="stats__value"><%= @stats[:likes_received] %></span>
      </li>
      <li class="stats__item">
        <span class="stats__label">おした いいね</span>
        <span class="stats__value"><%= @stats[:likes_given] %></span>
      </li>
      <li class="stats__item">
        <span class="stats__label">参加日</span>
        <span class="stats__value"><%= l @stats[:joined_on], format: :short %></span>
      </li>
    </ul>
  </section>


  <% if user_signed_in? && current_user.id == @user.id %>
    <section class="card u-show__card">
      <div class="card__header">
        <h3 class="card__title">保存した診断結果</h3>
        <% if @diagnoses.present? %>
          <%= link_to "診断履歴をすべて見る（#{@diagnoses_total}）", diagnoses_path, class: "btn btn--ghost" %>
        <% end %>
      </div>

      <% if @diagnoses.present? %>
        <ul class="list list--dense">
          <% @diagnoses.each do |d| %>
            <li class="list__item">
              <div class="list__meta"><%= l d.created_at, format: :short %></div>
              <div class="list__actions">
                <%= link_to "診断結果", diagnosis_path(d), class: "link" %>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="muted">まだ保存された診断はありません。</p>
        <%= link_to "診断をはじめる", diagnoses_questions_path, class: "btn btn--primary" %>
      <% end %>
    </section>
  <% end %>


  <% if @top_tags.present? %>
    <section class="card u-show__card">
      <h3 class="card__title">よく使うタグ TOP10</h3>
      <div class="chips">
        <% @top_tags.each do |(name, count)| %>
          <span class="chip">#<%= name %><span class="chip__count"><%= count %></span></span>
        <% end %>
      </div>
    </section>
  <% end %>


  <nav class="tabnav u-show__card">
    <%= link_to "投稿", user_path(@user, tab: "posts"),
      class: "tabnav__tab #{params[:tab] == 'likes' ? '' : 'is-active'}" %>
    <%= link_to "いいね", user_path(@user, tab: "likes"),
      class: "tabnav__tab #{params[:tab] == 'likes' ? 'is-active' : ''}" %>
  </nav>


  <section class="u-show__list">
    <% if @tweets.blank? %>
      <p class="muted">まだ表示する内容がありません。</p>
    <% else %>
      <% @tweets.each do |t| %>
        <article class="card tweet">
          <div class="tweet__meta">
            <span class="tweet__time"><%= l t.created_at, format: :short %></span>
            <span class="tweet__user"><%= t.user&.name || t.user&.email %></span>
          </div>

          <% if t.respond_to?(:artist) && t.respond_to?(:title) && (t.artist.present? || t.title.present?) %>
            <div class="tweet__song"><strong><%= t.artist %></strong> ― <%= t.title %></div>
          <% end %>

          <p class="tweet__body"><%= t.body %></p>

          <% if t.tags.present? %>
            <div class="chips chips--soft">
              <% t.tags.each do |tag| %>
                <span class="chip">#<%= tag.name %></span>
              <% end %>
            </div>
          <% end %>

          <div class="tweet__actions">
            <span class="likecount">❤︎ <%= t.likes.count %></span>
            <%= link_to "詳細", tweet_path(t), class: "btn btn--ghost" %>

            <% if user_signed_in? && current_user.id == t.user_id %>
              <%= link_to "編集", edit_tweet_path(t), class: "btn btn--ghost" %>
              <%= link_to "削除", tweet_path(t),
                    class: "btn btn--danger",
                    data: { turbo_method: :delete, turbo_confirm: "削除しますか？" } %>
            <% end %>
          </div>
        </article>
      <% end %>

      <div class="pagination">
        <div class="pagination__info"><%= page_entries_info @tweets %></div>
        <div class="pagination__links"><%= paginate @tweets %></div>
      </div>
    <% end %>
  </section>

  <div class="u-show__back">
    <%= link_to "← みんなの投稿一覧へ", tweets_path, class: "link" %>
  </div>
</div>
