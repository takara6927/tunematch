<div class="auth-links">
  <% if controller_name != 'sessions' %>
    <%= link_to "ログインはこちら", new_session_path(resource_name), class: "auth-link" %>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "新規登録はこちら", new_registration_path(resource_name), class: "auth-link" %>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "パスワードをお忘れの方", new_password_path(resource_name), class: "auth-link" %>
  <% end %>

  <% if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "確認メールを再送する", new_confirmation_path(resource_name), class: "auth-link" %>
  <% end %>

  <% if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "アカウントロック解除メールを再送する", new_unlock_path(resource_name), class: "auth-link" %>
  <% end %>

  <% if devise_mapping.omniauthable? %>
    <% resource_class.omniauth_providers.each do |provider| %>
      <%= button_to "#{OmniAuth::Utils.camelize(provider)}でログイン", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "auth-link" %>
    <% end %>
  <% end %>
</div>

<style>
  .auth-links {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-align: center;
  }

  .auth-link {
    display: inline-block;
    padding: 8px 14px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 700;
    color: #1f2937;
    background: #f3f4f6;
    text-decoration: none;
    transition: background 0.2s;
  }

  .auth-link:hover {
    background: #e5e7eb;
  }
</style>
