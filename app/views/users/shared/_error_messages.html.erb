<% if resource.errors.any? %>
  <div class="auth-error" data-turbo-cache="false">
    <h2 class="auth-error__title">
      入力内容に <%= resource.errors.count %> 件のエラーがあります
    </h2>
    <ul class="auth-error__list">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<style>
  .auth-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #b91c1c;
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 20px;
  }

  .auth-error__title {
    margin: 0 0 8px;
    font-size: 15px;
    font-weight: 800;
  }

  .auth-error__list {
    margin: 0;
    padding-left: 20px;
    font-size: 14px;
  }

  .auth-error__list li {
    list-style: disc;
    margin-bottom: 4px;
  }
</style>
