<h2>質問に答えてください</h2>

<%= form_with url: diagnoses_result_path, method: :post, data: { turbo: false } do |form| %>


  <% @questions.each_with_index do |q, i| %>
    <div>
      <p><%= q[:text] %></p>
      <%= radio_button_tag "answers[#{i}]", "yes", false, required: true %> はい
      <%= radio_button_tag "answers[#{i}]", "no", false %> いいえ
    </div>
  <% end %>
  <%= submit_tag "診断結果を見る"%>
<% end %>
