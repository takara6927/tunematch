<div class="tm-wrap">
  <header class="tm-header">
    <h1 class="tm-title">診断結果（履歴）</h1>
    <p class="tm-meta">
      保存日時：<span class="tm-date"><%= l @diagnosis.created_at, format: :short %></span>
    </p>
    <p class="tm-desc"><%= @diagnosis.result_summary %></p>
  </header>

  <% tracks = (@diagnosis.tracks || []) %>
  <% if tracks.any? %>
    <ol class="tm-tracks">
      <% tracks.each_with_index do |t, idx| %>
        <li class="tm-track">
          <div class="tm-track__head">
            <span class="tm-chip"><%= (idx+1).to_s.rjust(2,'0') %></span>
            <h2 class="tm-track__title"><%= t["title"] %> <span class="tm-artist">– <%= t["artist"] %></span></h2>
          </div>

          <% if (embed = youtube_embed_url(t["youtube_url"])) %>
            <div class="yt-wrap">
              <iframe
                src="<%= embed %>"
                title="<%= t["title"] %>"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"></iframe>
            </div>
          <% else %>
            <p class="tm-linkrow">
              <a class="tm-ext" href="<%= t["youtube_url"] %>" target="_blank" rel="noopener">YouTubeで見る</a>
            </p>
          <% end %>
        </li>
      <% end %>
    </ol>
  <% else %>
    <section class="tm-empty">
      <h2>この結果には表示できる曲がありません</h2>
      <p>トップの診断からあらためて実行してみてください。</p>
      <%= link_to "診断をはじめる", diagnoses_questions_path, class: "tm-btn" %>
    </section>
  <% end %>

  <section class="tm-share">
    <%= render "share_buttons",
        url: request.original_url,
        title: "診断結果",
        summary: @diagnosis.result_summary %>
  </section>

  <div class="tm-footer-actions">
    <%= link_to "履歴一覧へ戻る", diagnoses_path, class: "tm-btn tm-btn--ghost" %>
    <%= link_to "もう一度診断する", diagnoses_questions_path, class: "tm-btn" %>
  </div>
</div>

<style>
  .tm-wrap{max-width:980px;margin:40px auto;padding:0 16px}
  .tm-title{font-size:clamp(22px,3vw,30px);font-weight:900;color:var(--color-dark,#1F2937);margin:0 0 6px}
  .tm-meta{margin:0 0 4px;color:#6B7280}
  .tm-date{background:#F3F4F6;border-radius:999px;padding:2px 8px}
  .tm-desc{margin:10px 0 14px;color:#111827;font-weight:700}
  .tm-tracks{list-style:none;margin:0;padding:0;display:grid;gap:16px}
  .tm-track{background:#fff;border:1px solid rgba(31,41,55,.08);border-radius:16px;padding:16px;
            box-shadow:0 8px 24px rgba(31,41,55,.08)}
  .tm-track__head{display:flex;align-items:center;gap:10px;margin-bottom:10px}
  .tm-chip{background:var(--color-teal,#2ECAC3);color:#fff;font-weight:800;border-radius:999px;padding:4px 10px;font-size:12px}
  .tm-track__title{font-size:18px;margin:0;color:#111827;font-weight:800}
  .tm-artist{font-weight:600;color:#374151}
  .yt-wrap{position:relative;width:100%;max-width:720px;margin:12px auto;aspect-ratio:16/9;overflow:hidden;border-radius:12px;background:#000;box-shadow:0 6px 18px rgba(0,0,0,.25)}
  .yt-wrap iframe{position:absolute;inset:0;width:100%;height:100%}
  .tm-linkrow{margin:8px 0 0}
  .tm-ext{color:var(--color-teal,#2ECAC3);text-decoration:underline;font-weight:800}
  .tm-share{margin:18px 0}
  .tm-footer-actions{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-top:10px}
  .tm-btn{display:inline-block;background:linear-gradient(180deg,var(--color-teal,#2ECAC3),#1fb5ae);color:#fff;
          text-decoration:none;font-weight:900;padding:10px 18px;border-radius:12px;border:none}
  .tm-btn--ghost{background:#fff;color:var(--color-teal,#2ECAC3);border:2px solid var(--color-teal,#2ECAC3)}
  .tm-empty{background:var(--color-cream,#FFF8E7);border:1px dashed rgba(31,41,55,.2);border-radius:18px;padding:24px;text-align:center}
  @media (min-width:1024px){.yt-wrap{max-width:840px}}
</style>
