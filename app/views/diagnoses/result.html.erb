<div class="tm-wrap">
  <section class="tm-card">
    <h1 class="tm-title">あなたの診断結果</h1>
    <p class="tm-desc"><%= @result.description %></p>

    <div class="tm-grid">
      <article class="tm-block tm-block--teal">
        <div class="tm-ribbon">おすすめ①</div>
        <h2 class="tm-h2">おすすめアーティスト①：<%= @result.artist1 %></h2>
        <p class="tm-song"><strong>曲</strong>：<%= @result.song1 %></p>
        <% if (embed1 = youtube_embed_url(@result.youtube_url1)) %>
          <div class="tm-player">
            <iframe
              src="<%= embed1 %>"
              title="<%= @result.artist1 %> - <%= @result.song1 %>"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"></iframe>
          </div>
        <% end %>
      </article>

      <article class="tm-block tm-block--orange">
        <div class="tm-ribbon">おすすめ②</div>
        <h2 class="tm-h2">おすすめアーティスト②：<%= @result.artist2 %></h2>
        <p class="tm-song"><strong>曲</strong>：<%= @result.song2 %></p>
        <% if (embed2 = youtube_embed_url(@result.youtube_url2)) %>
          <div class="tm-player">
            <iframe
              src="<%= embed2 %>"
              title="<%= @result.artist2 %> - <%= @result.song2 %>"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"></iframe>
          </div>
        <% end %>
      </article>
    </div>

    <div class="tm-share">
      <%= render "share_buttons",
          url: request.original_url,
          title: diagnosis_display_title(@result),
          summary: @result.description %>
    </div>

    <div class="tm-save">
      <% if user_signed_in? %>
        <p class="tm-save__text">この結果はあなたの履歴に保存されました。</p>
        <%= link_to "履歴を見る", diagnoses_path, class: "tm-link" %>
      <% else %>
        <p class="tm-save__text">ログインすると結果を履歴に保存できます。</p>
        <%= link_to "ログインする", new_user_session_path, class: "tm-link" %>
      <% end %>
    </div>

    <div class="tm-actions">
      <%= link_to "もう一度診断する", diagnoses_questions_path, class: "tm-btn tm-btn--ghost" %>
    </div>
  </section>
</div>

<style>
  .tm-wrap{max-width:1000px;margin:40px auto;padding:0 16px}
  .tm-card{
    background:
      radial-gradient(800px 400px at -10% -20%, rgba(46,202,195,.15), transparent 55%),
      radial-gradient(700px 500px at 110% 0%, rgba(246,210,77,.18), transparent 55%),
      #fff;
    border-radius:22px;padding:26px;border:1px solid rgba(31,41,55,.08);box-shadow:0 10px 30px rgba(31,41,55,.12)
  }
  .tm-title{font-size:clamp(22px,3vw,30px);font-weight:900;color:var(--color-dark,#1F2937);margin:0 0 10px}
  .tm-desc{color:#374151;margin:0 0 20px}
  .tm-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px}
  .tm-block{position:relative;border-radius:18px;padding:18px;border:1px solid rgba(31,41,55,.08);background:#fff;overflow:hidden}
  .tm-block--teal{background:
      linear-gradient(180deg,rgba(46,202,195,.14),transparent 55%),
      var(--color-cream,#FFF8E7)}
  .tm-block--orange{background:
      linear-gradient(180deg,rgba(255,138,61,.14),transparent 55%),
      var(--color-cream,#FFF8E7)}
.tm-ribbon{
  position:absolute;
  top:12px;right:-26px;
  transform:rotate(20deg);
  background: var(--color-yellow,#F6D24D);
  color:#5a2a00;
  font-weight:900;
  font-size:12px;
  padding:4px 36px;
  border-radius:6px;
}
  .tm-h2{font-size:18px;margin:0 0 6px;color:#111827;font-weight:800}
  .tm-song{margin:0 0 10px;color:#374151}
  .tm-player{position:relative;padding-top:56.25%;border-radius:12px;overflow:hidden;background:#000;box-shadow:0 6px 18px rgba(0,0,0,.25)}
  .tm-player iframe{position:absolute;inset:0;width:100%;height:100%}
  .tm-share{margin:18px 0}
  .tm-save{display:flex;align-items:center;gap:10px;flex-wrap:wrap;background:#F9FAFB;border:1px dashed rgba(31,41,55,.2);padding:12px 14px;border-radius:12px}
  .tm-save__text{margin:0;color:#374151}
  .tm-link{color:var(--color-teal,#2ECAC3);text-decoration:underline;font-weight:800}
  .tm-actions{margin-top:22px;text-align:center}
  .tm-btn{display:inline-block;background:linear-gradient(180deg,var(--color-teal,#2ECAC3),#1fb5ae);color:#fff;
          text-decoration:none;font-weight:900;padding:12px 24px;border-radius:14px;border:none}
  .tm-btn--ghost{background:#fff;color:var(--color-teal,#2ECAC3);border:2px solid var(--color-teal,#2ECAC3)}
  @media (max-width:760px){.tm-grid{grid-template-columns:1fr}}
</style>
